<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

  .navbar-black {
    background-color: #000 !important;
  }

  .navbar-black .nav-link, .navbar-black .navbar-brand {
    color: #fff !important;
    font-size: 0.95rem;
  }

  .navbar-black .nav-link.active {
    color: #dc3545 !important;
  }

</style>

<nav class="navbar navbar-expand-lg navbar-black">

  <div class="container-fluid">

    <a class="navbar-brand" href="/">Logo</a>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">

      <span class="navbar-toggler-icon"></span>

    </button>

    <div class="collapse navbar-collapse" id="navbarNav">

      <ul class="navbar-nav ms-auto">

        <li class="nav-item mx-2">
          <a class="nav-link<%= (title === 'Site de Filmes') ? ' active' : '' %>" aria-current="page" href="/">Home</a>
        </li>

        <li class="nav-item mx-2">
          <a class="nav-link<%= (title === 'About') ? ' active' : '' %>" href="/about">About</a>
        </li>

        <li class="nav-item mx-2">
          <a class="nav-link<%= (title === 'Partner') ? ' active' : '' %>" href="/partner">Partner</a>
        </li>

        <li class="nav-item mx-2">
          <a class="nav-link<%= (title === 'Contact') ? ' active' : '' %>" href="/contact">Contact</a>
        </li>

        <% if (!isLoggedIn) { %>

          <li class="nav-item mx-2">
            <a class="nav-link<%= (title === 'Register') ? ' active' : '' %>" href="/register">Register</a>
          </li>

          <li class="nav-item mx-2">
            <a class="nav-link<%= (title === 'Login') ? ' active' : '' %>" href="/login">Login</a>
          </li>

        <% } else { %>
          
          <li class="nav-item mx-2">
            <a class="nav-link" href="/logout">Sair</a>
          </li>

        <% } %>

      </ul>

    </div>
    
  </div>

</nav>
