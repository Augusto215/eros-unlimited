<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="/style.css">

<style>

  .navbar-black {
    background-color: #000 !important;
  }

  .navbar-black .nav-link, .navbar-black .navbar-brand {
    color: #fff !important;
    font-size: 0.95rem;
  }

  .navbar-black .nav-link.active {
    color: #dc3545 !important;
  }

</style>

<nav class="navbar navbar-expand-lg navbar-black">

  <div class="container-fluid">

    <a class="navbar-brand" href="/">Logo</a>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">

      <span class="navbar-toggler-icon"></span>

    </button>

    <div class="collapse navbar-collapse" id="navbarNav">

      <ul class="navbar-nav ms-auto">

        <li class="nav-item mx-2">
          <a class="nav-link<%= (title === 'Site de Filmes') ? ' active' : '' %>" aria-current="page" href="/">Home</a>
        </li>

        <li class="nav-item mx-2">
          <a class="nav-link<%= (title === 'About') ? ' active' : '' %>" href="/about">About</a>
        </li>

        <li class="nav-item mx-2">
          <a class="nav-link<%= (title === 'Partner') ? ' active' : '' %>" href="/partner">Partner</a>
        </li>

        <li class="nav-item mx-2">
          <a class="nav-link<%= (title === 'Contact') ? ' active' : '' %>" href="/contact">Contact</a>
        </li>

        <% if (!isLoggedIn) { %>

          <li class="nav-item mx-2">
            <a class="nav-link<%= (title === 'Register') ? ' active' : '' %>" href="/register">Register</a>
          </li>

          <li class="nav-item mx-2">
            <a class="nav-link<%= (title === 'Login') ? ' active' : '' %>" href="/login">Login</a>
          </li>

        <% } else { %>

          <li class="nav-item mx-2">
            <a class="nav-link<%= (title === 'Movies') ? ' active' : '' %>" href="/movies">Movies</a>
          </li>
          
          <li class="nav-item mx-2">
            <a class="nav-link" href="#" data-bs-toggle="modal" data-bs-target="#logoutModal">Exit</a>
          </li>

        <% } %>

      </ul>

    </div>
    
  </div>

</nav>

<!-- Modal de Confirmação de Logout -->
<div class="modal fade" id="logoutModal" tabindex="-1" aria-labelledby="logoutModalLabel" aria-hidden="true">

  <div class="modal-dialog modal-dialog-centered modal-sm">

    <div class="modal-content">

      <div class="modal-header border-0">

        <h5 class="modal-title" id="logoutModalLabel">Confirm logout</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>

      </div>

      <div class="modal-body text-center">

        <p>Are you sure you want to log out?</p>

      </div>

      <div class="modal-footer border-0 justify-content-center w-100">

        <div class="row w-100">

          <div class="col-6 pe-1">

            <button type="button" class="btn btn-secondary w-100" data-bs-dismiss="modal">Cancel</button>

          </div>

          <div class="col-6 ps-1">
            
            <a href="/logout" class="btn btn-danger w-100">
              <i class="bi bi-box-arrow-right me-1"></i> Exit
            </a>

          </div>
          
        </div>

      </div>

    </div>

  </div>
  
</div>